# OpenClaw stack env template
#
# Use this file as a source for Portainer stack environment values.
# Do not commit real secrets.

# Required: long random token used by the OpenClaw gateway.
# Generate with:
#   openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=replace-with-random-token

# Required for the phase-1 Discord DM rollout.
# Create a Discord application + bot, then copy the bot token here.
DISCORD_BOT_TOKEN=replace-with-discord-bot-token

# Required if you want OpenClaw to use OpenAI API-key auth.
# Get this from the OpenAI Platform dashboard.
# Current recommended working model after deploy:
#   openai/gpt-5.4-mini
OPENAI_API_KEY=replace-with-openai-api-key

# Optional: container timezone. Defaults to Asia/Kolkata in the compose file.
OPENCLAW_TZ=Asia/Kolkata
